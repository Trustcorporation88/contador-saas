# Copie para .env e preencha as senhas dos certificados em empresas.json
# DATABASE_URL deve usar o host PUBLICO do Railway (thomas.proxy.rlwy.net), nao o .internal

DATABASE_URL=postgresql://postgres:SUA_SENHA@thomas.proxy.rlwy.net:21158/railway

FISCAL_AUTOMATION_DIR=C:\contador-saas\contador-saas\automacao-xml
FISCAL_XML_ROOT=C:\contador-saas\contador-saas\automacao-xml\xmls
FISCAL_CERTS_DIR=C:\contador-saas\contador-saas\automacao-xml\certs
FISCAL_SYNC_DB=C:\contador-saas\contador-saas\automacao-xml\sync.db

PYTHON_BIN=python
FISCAL_HOMOLOGACAO=false

# Portal Nacional NFS-e (ajuste se necessario)
NFSE_API_BASE=https://adn.nfse.gov.br/contribuintes
