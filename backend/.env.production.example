# =============================================
# CONTADOR SAAS - VARIÁVEIS DE PRODUÇÃO
# Copie este arquivo para .env e preencha
# NUNCA commite o arquivo .env real no git!
# =============================================

# ── Aplicação ────────────────────────────────
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
APP_VERSION=1.0.0

# ── Banco de dados PostgreSQL ─────────────────
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/BANCO
DATABASE_URL=postgresql://USUARIO:SENHA@HOST:5432/BANCO

# ── Cache Redis ───────────────────────────────
# Formato com senha: redis://:SENHA@HOST:6379
# Render Redis: redis://red-XXXXXX:6379
REDIS_URL=redis://:SENHA@HOST:6379
REDIS_HOST=HOST
REDIS_PORT=6379
REDIS_PASSWORD=GERE_UMA_SENHA_REDIS_FORTE_AQUI
REDIS_DB=0

# ── Segurança JWT ─────────────────────────────
# Gere com: openssl rand -base64 64
JWT_SECRET=GERE_UM_SECRET_FORTE_AQUI_MINIMO_64_CARACTERES_ALEATORIOS
JWT_EXPIRES_IN=24h

# Gere um diferente do JWT_SECRET acima
REFRESH_TOKEN_SECRET=GERE_OUTRO_SECRET_FORTE_DIFERENTE_DO_JWT_MINIMO_64_CHARS
REFRESH_TOKEN_EXPIRES_IN=7d

# Criptografia extra para tokens (opcional, AES-256 = 32 bytes)
# Gere com: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=GERE_UMA_CHAVE_HEX_64_CHARS_AQUI

# ── Cache TTLs (segundos) ─────────────────────
CACHE_ENABLED=true
CACHE_REPORTS_TTL=300
CACHE_ACCOUNTS_TTL=900
CACHE_TAXES_TTL=3600
CACHE_DASHBOARD_TTL=120

# ── Rate Limiting ─────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_MAX_LOGIN=5

# ── Email SMTP (para notificações) ────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
# Use "App Password" do Google, não a senha normal
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
SMTP_FROM=noreply@ocontador.app

# ── DeepSeek AI (opcional) ────────────────────
# Obtenha em: https://platform.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# ── Sentry (monitoramento de erros — opcional) ──
# Obtenha em: https://sentry.io
SENTRY_DSN=https://HASH@PROJETO.ingest.sentry.io/NUMERO

# ── Logs ──────────────────────────────────────
# Níveis: error | warn | info | debug
LOG_LEVEL=warn
LOG_FILE=/var/log/contador/app.log
# Dias para reter arquivos de log
LOG_RETENTION_DAYS=30

# ── CORS ──────────────────────────────────────
# URL do frontend (sem barra no final)
CORS_ORIGIN=https://app.ocontador.app

# ── Backup automático (opcional) ─────────────
# Cron schedule (padrão: todo dia à 1h)
BACKUP_CRON=0 1 * * *
BACKUP_RETENTION_DAYS=30
