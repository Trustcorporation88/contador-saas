{
  "name": "contador-backend",
  "version": "1.0.0",
  "description": "Backend Node.js/Express para sistema de contabilidade - Contador App",
  "main": "dist/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "ts-node --transpile-only src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc",
    "seed:dev-user": "ts-node --transpile-only src/scripts/seedDevUser.ts",
    "migrate": "ts-node --transpile-only src/scripts/runMigrations.ts",
    "prepare:docker": "powershell -ExecutionPolicy Bypass -File scripts/prepare-docker-context.ps1",
    "deploy:railway": "cd .. && railway up --detach --service contador-api",
    "build:watch": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "prebuild": "npm run clean",
    "prepare": "npm run build"
  },
  "keywords": [
    "contabilidade",
    "accounting",
    "contador",
    "enterprise"
  ],
  "author": "Backend Team",
  "license": "MIT",
  "dependencies": {
    "@types/multer": "^2.1.0",
    "axios": "^1.6.5",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "fs-extra": "^11.3.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.10.1",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "luxon": "^3.7.2",
    "multer": "^2.1.1",
    "node-cache": "^5.1.2",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.8",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.15.2",
    "pg": "^8.11.3",
    "speakeasy": "^2.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/ioredis": "^4.28.10",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.10.5",
    "@types/node-cron": "^3.0.11",
    "@types/pdfkit": "^0.13.9",
    "@types/pg": "^8.11.2",
    "@types/speakeasy": "^2.0.10",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "supertest": "^6.3.3",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
