# Node Environment
NODE_ENV=development

# Server Configuration
PORT=3000
HOST=0.0.0.0

# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql://contador_user:contador_password@localhost:5432/contador_db
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=contador_db
DATABASE_USER=contador_user
DATABASE_PASSWORD=contador_password

# Connection Pool Configuration
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_IDLE_TIMEOUT_MILLIS=30000
DATABASE_CONNECTION_TIMEOUT_MILLIS=2000

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRY=1h
JWT_REFRESH_EXPIRY=7d
JWT_ALGORITHM=HS256

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,http://localhost:8080
CORS_CREDENTIALS=true

# Logging Configuration
LOG_LEVEL=debug
LOG_FORMAT=json

# Security
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCK_TIME_MINUTES=15

# Cache Configuration
CACHE_DEFAULT_TTL=3600
CACHE_MAX_KEYS=1000

# API Configuration
API_VERSION=v1
API_TIMEOUT=30000

# SMTP Configuration (opcional)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_password
SMTP_FROM=noreply@contador.app

# TOTP Configuration (2FA)
TOTP_WINDOW=2
TOTP_ISSUER=Contador App

# Feature Flags
ENABLE_2FA=true
ENABLE_AUDIT_LOG=true
ENABLE_RATE_LIMITING=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000

# External Services (opcional)
STRIPE_API_KEY=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# DeepSeek AI — Copiloto Contábil
# Obtenha em: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
